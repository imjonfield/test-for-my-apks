<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:weightSum="10.0"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <include
        android:id="@id/sign_up_multiscreen_toolbar_include"
        layout="@layout/toolbar_include" />
    <FrameLayout
        android:id="@id/sign_up_multiscreen_content_layout"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        android:layout_weight="9.0" />
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        android:layout_marginLeft="12.0dip"
        android:layout_marginRight="12.0dip"
        android:layout_weight="1.0">
        <LinearLayout
            android:orientation="horizontal"
            android:id="@id/sign_up_multiscreen_footer_layout"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:weightSum="8.0">
            <TextView
                android:background="@color/RbxGray2"
                android:layout_width="0.0dip"
                android:layout_height="6.0dip"
                android:layout_marginRight="6.0dip"
                android:layout_weight="2.0"
                android:layout_marginEnd="6.0dip" />
            <TextView
                android:background="@color/RbxGray3"
                android:layout_width="0.0dip"
                android:layout_height="6.0dip"
                android:layout_marginRight="6.0dip"
                android:layout_weight="2.0"
                android:layout_marginEnd="6.0dip" />
            <TextView
                android:background="@color/RbxGray3"
                android:layout_width="0.0dip"
                android:layout_height="6.0dip"
                android:layout_marginRight="6.0dip"
                android:layout_weight="2.0"
                android:layout_marginEnd="6.0dip" />
            <TextView
                android:background="@color/RbxGray3"
                android:layout_width="0.0dip"
                android:layout_height="6.0dip"
                android:layout_weight="2.0" />
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12.0dip">
            <com.roblox.client.components.RbxTextView
                android:textSize="16.0sp"
                android:textColor="@color/RbxGray2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="10.0dip"
                android:text="@string/Authentication_SignUp_Label_AlreadyHaveAnAccount"
                android:layout_marginEnd="10.0dip" />
            <com.roblox.client.components.RbxTextView
                android:textSize="16.0sp"
                android:textColor="@color/RbxBlue1"
                android:id="@id/sign_up_multiscreen_login_textview"
                android:padding="5.0dip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/Authentication_SignUp_Label_Login" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>