<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <include
        android:id="@id/toolbar_chat"
        layout="@layout/toolbar_include" />
    <RelativeLayout
        android:id="@id/chat_list_disabled"
        android:background="@color/chatBackground"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">
        <com.roblox.client.components.RbxTextView
            android:textSize="16.0sp"
            android:gravity="center"
            android:id="@id/chat_disabled_hint"
            android:paddingLeft="50.0dip"
            android:paddingRight="50.0dip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/Feature_Chat_Label_TurnOnChatInSettings"
            android:layout_centerInParent="true"
            style="@style/Theme.Roblox.StandardFontRegular" />
        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5.0dip"
            android:src="@drawable/symbol_friends"
            android:layout_above="@id/chat_disabled_hint"
            android:layout_centerHorizontal="true" />
    </RelativeLayout>
</LinearLayout>