<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:background="@color/chatBackground"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.roblox.client.components.RbxTextView
        android:textSize="@dimen/chatConversationViewTimeText"
        android:textColor="@color/chatSubText"
        android:id="@id/message_time"
        android:padding="4.0dip"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/Feature_Chat_Label_DummyTime"
        android:layout_centerHorizontal="true"
        style="@style/Theme.Roblox.StandardFontRegular" />
    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@id/message_thumbnail"
        android:layout_width="38.0dip"
        android:layout_height="38.0dip"
        android:layout_marginLeft="5.0dip"
        android:src="@drawable/ic_launcher_transparent"
        android:layout_below="@id/message_time"
        android:layout_alignParentLeft="true"
        app:civ_border_width="0.0dip"
        app:civ_border_color="@color/chatSecondary"
        app:civ_fill_color="@color/white" />
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/message_bubble"
        android:background="@drawable/chat_bubble_white_v2"
        android:paddingLeft="12.0dip"
        android:paddingTop="8.0dip"
        android:paddingRight="12.0dip"
        android:paddingBottom="9.0dip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="12.0dip"
        android:layout_marginRight="12.0dip"
        android:minHeight="38.0dip"
        android:layout_toRightOf="@id/message_thumbnail"
        android:layout_below="@id/message_time">
        <com.roblox.client.components.RbxTextView
            android:textSize="@dimen/chatConversationViewAuthorText"
            android:textColor="@color/chatSubText"
            android:id="@id/message_author"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Theme.Roblox.StandardFontRegular" />
        <com.rockerhieu.emojicon.EmojiconTextView
            android:textSize="@dimen/chatConversationViewContentText"
            android:textColor="@color/chatPrimary"
            android:id="@id/message_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="" />
    </LinearLayout>
    <ImageView
        android:id="@id/message_bubble_ear"
        android:visibility="visible"
        android:layout_width="10.0dip"
        android:layout_height="15.0dip"
        android:layout_marginLeft="-7.0dip"
        android:layout_marginTop="10.0dip"
        android:src="@drawable/chat_bubble_white_ear_v2"
        android:scaleType="fitXY"
        android:layout_alignLeft="@id/message_bubble"
        android:layout_alignTop="@id/message_bubble" />
</RelativeLayout>