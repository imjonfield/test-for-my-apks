<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:background="@drawable/rbx_bg_card_shadow"
        android:paddingLeft="12.0dip"
        android:paddingTop="12.0dip"
        android:paddingRight="12.0dip"
        android:paddingBottom="18.0dip"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12.0dip"
        xmlns:android="http://schemas.android.com/apk/res/android">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="18.0sp"
                android:textColor="@color/RbxBlack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/Authentication_SignUp_Label_AlmostThere"
                style="@style/Theme.Roblox.StandardFontBold" />
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12.0dip">
                <com.roblox.client.components.RbxCheckBox
                    android:textSize="@dimen/textSizeSignupFinePrint"
                    android:id="@id/sign_up_agreement_checkbox"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="12.0dip" />
                <com.roblox.client.components.RbxTextView
                    android:textSize="@dimen/textSizeSignupFinePrint"
                    android:textColor="@color/shell_text_normal"
                    android:gravity="start"
                    android:id="@id/sign_up_agreement_textview"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/CommonUI_Features_Label_LoremIpsumXl"
                    style="@style/Theme.Roblox.StandardFontLight" />
            </LinearLayout>
            <com.roblox.client.components.RbxTextView
                android:textAppearance="?android:textAppearanceSmall"
                android:textSize="@dimen/rbxEditTextHint"
                android:textColor="@color/RbxRed2"
                android:id="@id/sign_up_error_agreement_textview"
                android:background="@android:color/transparent"
                android:visibility="invisible"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:text="@string/Authentication_SignUp_Label_PleaseAgreeToTerms" />
        </LinearLayout>
    </LinearLayout>
    <com.roblox.client.components.RbxProgressButton
        android:layout_gravity="bottom"
        android:id="@id/sign_up_tos_done_button"
        android:layout_width="fill_parent"
        android:layout_height="40.0dip"
        android:layout_marginLeft="12.0dip"
        android:layout_marginRight="12.0dip"
        android:layout_marginBottom="12.0dip"
        app:defButtonText="@string/CommonUI_Features_Action_Done"
        app:progressTextSize="@dimen/textSizeBtnSubmitProgress"
        app:buttonTextSize="@dimen/textSizeBtnSubmit"
        style="@style/Theme.Roblox.Progress.Button.Blue" />
</LinearLayout>