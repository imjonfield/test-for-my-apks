<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:gravity="center_horizontal"
    android:orientation="horizontal"
    android:background="@drawable/home_bkg"
    android:padding="16.0dip"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:weightSum="5.0"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:background="@drawable/background_2sv_rounded_white"
        android:paddingLeft="20.0dip"
        android:paddingTop="10.0dip"
        android:paddingRight="20.0dip"
        android:paddingBottom="10.0dip"
        android:layout_width="0.0dip"
        android:layout_height="fill_parent"
        android:weightSum="7.0"
        android:layout_weight="3.0">
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:layout_width="fill_parent"
            android:layout_height="0.0dip"
            android:layout_weight="3.0">
            <TextView
                android:textSize="20.0sp"
                android:textColor="@android:color/black"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20.0dip"
                android:text="@string/Authentication_2SV_Label_TwoStepVerification"
                style="Theme.Roblox.StandardFontRegular" />
            <ImageView
                android:id="@id/imageview_2sv_logo"
                android:layout_width="fill_parent"
                android:layout_height="0.0dip"
                android:src="@drawable/two_step_verification_logo_email"
                android:layout_weight="1.0"
                android:contentDescription="@string/Authentication_2SV_Label_TwoStepVerification" />
            <TextView
                android:textSize="16.0sp"
                android:textColor="@color/black"
                android:gravity="center"
                android:id="@id/textview_2sv_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/Authentication_2SV_Label_EnterEmailCode"
                style="Theme.Roblox.StandardFontRegular" />
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10.0dip"
            android:layout_marginBottom="5.0dip"
            android:weightSum="6.0">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_weight="4.0">
                <EditText
                    android:textSize="16.0sp"
                    android:textColor="@color/RbxGray7"
                    android:textColorHint="@color/RbxGray7"
                    android:id="@id/edittext_verify_code"
                    android:background="@drawable/edit_red_border"
                    android:padding="15.0dip"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="10.0dip"
                    android:hint="@string/Authentication_2SV_Label_EnterCode"
                    android:inputType="number"
                    android:imeOptions="actionDone"
                    style="Theme.Roblox.StandardFontRegular" />
                <TextView
                    android:textSize="16.0sp"
                    android:textColor="@color/RbxRed1"
                    android:id="@id/textview_incorrect_code_signal"
                    android:visibility="invisible"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10.0dip"
                    android:text="@string/Authentication_2SV_Response_TwoStepEmptyCode" />
            </LinearLayout>
            <com.roblox.client.components.RbxProgressButton
                android:id="@id/button_verify_code"
                android:layout_width="0.0dip"
                android:layout_height="50.0dip"
                android:layout_weight="2.0"
                android:contentDescription="@string/Authentication_2SV_Label_TwoStepVerification"
                app:defButtonText="@string/Authentication_2SV_Action_Verify"
                app:progressTextSize="16.0sp"
                app:buttonTextSize="16.0sp"
                style="@style/Theme.Roblox.Progress.Button.Green" />
        </LinearLayout>
        <android.support.v7.widget.AppCompatCheckBox
            android:textSize="16.0sp"
            android:textColor="@color/black"
            android:layout_gravity="center_horizontal"
            android:id="@id/checkbox_2sv_trust_device"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/Authentication_2SV_Label_TrustThisDevice"
            app:buttonTint="@color/RbxGreen2"
            style="Theme.Roblox.StandardFontRegular" />
        <TextView
            android:textSize="16.0sp"
            android:textColor="@color/blueRobloxSupport"
            android:id="@id/textview_2sv_resend_code"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10.0dip"
            android:text="@string/Authentication_2SV_Action_ResendCode"
            style="Theme.Roblox.StandardFontRegular" />
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20.0dip">
            <TextView
                android:textSize="14.0sp"
                android:id="@id/textview_2sv_support"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="Theme.Roblox.StandardFontRegular" />
        </LinearLayout>
        <View
            android:layout_width="fill_parent"
            android:layout_height="0.0dip"
            android:layout_weight="4.0" />
    </LinearLayout>
</LinearLayout>